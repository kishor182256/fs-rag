{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3WriteRawUploads",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::aws-rag-demos/ingestion/raw/*"
      ]
    },
    {
      "Sid": "S3ListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::aws-rag-demos"]
    },
    {
      "Sid": "SqsEnqueue",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": ["<SQS_QUEUE_ARN>"]
    },
    {
      "Sid": "DynamoJobsWriteRead",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:GetItem",
        "dynamodb:UpdateItem",
        "dynamodb:Scan"
      ],
      "Resource": ["<DYNAMODB_TABLE_ARN>"]
    },
    {
      "Sid": "BedrockInvoke",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": ["*"]
    },
    {
      "Sid": "ReadQdrantSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "kms:Decrypt"
      ],
      "Resource": [
        "<QDRANT_SECRET_ARN>",
        "<KMS_KEY_ARN>"
      ]
    }
  ]
}


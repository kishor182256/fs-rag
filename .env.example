APP_NAME=PDF Ingestion API
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
MAX_UPLOAD_SIZE_MB=25
CHUNK_SIZE=700
CHUNK_OVERLAP=100
MIN_CHUNK_CHARS=120
MIN_PAGE_TEXT_CHARS=80
ENABLE_OCR_FALLBACK=false
UPLOAD_DIR=data/uploads
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=qwen2.5:7b
EMBEDDING_MODEL=nomic-embed-text
LLM_TIMEOUT_SECONDS=30
EMBEDDING_TIMEOUT_SECONDS=30
ENABLE_VECTOR_INDEXING=true
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_chunks
HF_QDRANT_COLLECTION=rag_chunks_hf
FORCE_HF_RETRIEVAL_COLLECTION=true
VECTOR_DISTANCE=cosine
VECTOR_QUERY_LIMIT=8
BM25_K1=1.5
BM25_B=0.75
ENABLE_HF_CHUNK_ENRICHMENT=false
HF_TOPIC_MODEL_NAME=facebook/bart-large-mnli
HF_NER_MODEL_NAME=dslim/bert-base-NER
HF_CHUNK_TYPE_MIN_SCORE=0.2
HF_ENRICHMENT_MAX_CHARS=1600
HF_ENRICHMENT_ENTITY_LIMIT=12
ENABLE_HF_RERANKER=false
HF_RERANKER_MODEL_NAME=BAAI/bge-reranker-base
HF_RERANKER_TOP_N=30
HF_RERANKER_WEIGHT=0.35
HF_RERANKER_BATCH_SIZE=8
HF_RERANKER_MAX_LENGTH=512
SEARCH_MIN_SCORE=0.01
SEARCH_RELATIVE_SCORE_RATIO=0.6
SEARCH_MIN_KEYWORD_COVERAGE=0.35
LLM_MAX_CONTEXT_HITS=3
